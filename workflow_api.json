{
  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan2.1_i2v_480p_14B_fp16.safetensors",
      "base_precision": "bf16"
    }
  },
  "2": {
    "class_type": "MultiTalkModelLoader",
    "inputs": {
      "model": "infinitetalk.safetensors",
      "base_precision": "bf16",
      "wav2vec_path": "wav2vec"
    }
  },
  "3": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "t5_model": "umt5_xxl_fp16.safetensors",
      "precision": "bf16"
    }
  },
  "4": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "vae_model": "wan_2.1_vae.safetensors"
    }
  },
  "5": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input_image.png"
    }
  },
  "11": {
    "class_type": "LoadAudio",
    "inputs": {
      "audio": "input_audio.mp3"
    }
  },
  "15": {
    "class_type": "ImageResizeKJv2",
    "inputs": {
      "image": ["10", 0],
      "width": 832,
      "height": 480,
      "interpolation": "lanczos",
      "keep_proportion": true,
      "divisible_by": 16,
      "condition": "always"
    }
  },
  "20": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "text_encoder": ["3", 0],
      "prompt": "A person speaking naturally to camera, professional setting, clear speech, subtle natural head movements"
    }
  },
  "21": {
    "class_type": "WanVideoClipVisionEncode",
    "inputs": {
      "clip_vision": ["5", 0],
      "image": ["15", 0]
    }
  },
  "22": {
    "class_type": "MultiTalkWav2VecEmbeds",
    "inputs": {
      "multitalk_model": ["2", 0],
      "audio": ["11", 0]
    }
  },
  "30": {
    "class_type": "WanVideoImageToVideoMultiTalk",
    "inputs": {
      "multitalk_model": ["2", 0],
      "clip_vision_output": ["21", 0],
      "image": ["15", 0],
      "wav2vec_embeds": ["22", 0],
      "width": 832,
      "height": 480,
      "motion_frame": 81,
      "frame_window": 81
    }
  },
  "40": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["20", 0],
      "negative": ["20", 1],
      "image_embeds": ["30", 0],
      "samples": null,
      "seed": 42,
      "steps": 20,
      "cfg": 3.0,
      "shift": 5.0,
      "scheduler": "flow_shift",
      "denoise_strength": 1.0
    }
  },
  "50": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["4", 0],
      "samples": ["40", 0]
    }
  },
  "60": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["50", 0],
      "audio": ["11", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "infinitetalk_output",
      "format": "video/h264-mp4",
      "save_output": true
    }
  }
}
